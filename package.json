{
  "name": "x-to-zod",
  "version": "0.10.2",
  "description": "Enhanced fork of json-schema-to-zod - Converts JSON Schema into Zod schemas with fluent builder pattern",
  "packageManager": "pnpm@10.32.0",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "types": "./dist/types/index.d.ts",
  "bin": "./dist/cjs/cli.js",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./v3": {
      "import": {
        "types": "./dist/types/v3.d.ts",
        "default": "./dist/esm/v3.js"
      },
      "require": {
        "types": "./dist/types/v3.d.ts",
        "default": "./dist/cjs/v3.js"
      }
    },
    "./v4": {
      "import": {
        "types": "./dist/types/v4.d.ts",
        "default": "./dist/esm/v4.js"
      },
      "require": {
        "types": "./dist/types/v4.d.ts",
        "default": "./dist/cjs/v4.js"
      }
    },
    "./builders": {
      "types": "./dist/types/ZodBuilder/index.d.ts",
      "import": "./dist/esm/ZodBuilder/index.js",
      "require": "./dist/cjs/ZodBuilder/index.js"
    },
    "./parsers/json": {
      "types": "./dist/types/JsonSchema/index.d.ts",
      "import": "./dist/esm/JsonSchema/index.js",
      "require": "./dist/cjs/JsonSchema/index.js"
    },
    "./post-processing": {
      "types": "./dist/types/PostProcessing/index.d.ts",
      "import": "./dist/esm/PostProcessing/index.js",
      "require": "./dist/cjs/PostProcessing/index.js"
    }
  },
  "scripts": {
    "build:types": "tsgo -p tsconfig.types.json",
    "build:cjs": "tsgo -p tsconfig.cjs.json && node postcjs.js",
    "build:esm": "tsgo -p tsconfig.esm.json && node postesm.js",
    "build": "rimraf ./dist && pnpm run build:types && pnpm run build:cjs && pnpm run build:esm",
    "dry": "pnpm run build && pnpm publish --dry-run",
    "dev": "vitest",
    "test": "vitest run --test-timeout=60000",
    "lint": "oxlint src test",
    "lint:fix": "oxlint --fix src test",
    "format": "oxfmt src test *.ts",
    "format:check": "oxfmt --check src test *.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepare": "simple-git-hooks",
    "type-check": "tsgo --noEmit",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "docs": "typedoc",
    "docs:md": "typedoc --options typedoc.md.json",
    "docs:all": "pnpm docs && pnpm docs:md"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run type-check"
  },
  "c8": {
    "exclude": [
      "dist",
      "postcjs.js",
      "postesm.js",
      "test"
    ]
  },
  "keywords": [
    "zod",
    "json",
    "schema",
    "converter",
    "cli",
    "json-schema-to-zod",
    "zod-codegen",
    "schema-converter",
    "json-schema",
    "validation",
    "typescript-codegen"
  ],
  "author": "Pradeep Mouli <pmouli@mac.com> (https://github.com/pradeepmouli)",
  "contributors": [
    "Stefan Terdell (Original Author)",
    "Chen (https://github.com/werifu)",
    "Nuno Carduso (https://github.com/ncardoso-barracuda)",
    "Lars Strojny (https://github.com/lstrojny)",
    "Navtoj Chahal (https://github.com/navtoj)",
    "Ben McCann (https://github.com/benmccann)",
    "Dmitry Zakharov (https://github.com/DZakh)",
    "Michel Turpin (https://github.com/grimly)",
    "David Barratt (https://github.com/davidbarratt)",
    "pevisscher (https://github.com/pevisscher)",
    "Aidin Abedi (https://github.com/aidinabedi)",
    "Brett Zamir (https://github.com/brettz9)",
    "vForgeOne (https://github.com/vforgeone)",
    "Adrian Ordonez (https://github.com/adrianord)",
    "Jonas Reucher (https://github.com/Mantls)"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepmouli/x-to-zod"
  },
  "homepage": "https://pradeepmouli.github.io/x-to-zod/",
  "bugs": {
    "url": "https://github.com/pradeepmouli/x-to-zod/issues"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@to-skills/vitepress": "^0.2.17",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "fast-diff": "^1.3.0",
    "lint-staged": "^16.4.0",
    "openapi-types": "^12.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.61.0",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "type-fest": "^5.6.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-to-skills": "^0.6.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "json-schema-typed": "^8.0.2",
    "tinyglobby": "^0.2.16"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7.3.2",
      "rollup": "^4.43.0",
      "flatted": "^3.4.2",
      "minimatch": ">=9.0.5",
      "picomatch": ">=2.3.2"
    }
  }
}
